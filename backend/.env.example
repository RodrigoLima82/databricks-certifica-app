# ── Modo ──────────────────────────────────────────────────────────────────────
# true  = dev local sem Databricks/Lakebase (usa seed/seed_data.json)
# false = produção/staging com Lakebase
MOCK_MODE=true

# ── Databricks (necessário com MOCK_MODE=false) ────────────────────────────────
DATABRICKS_HOST=https://<seu-workspace>.cloud.databricks.com
DATABRICKS_TOKEN=dapi...

# ── Lakebase (Postgres) ─────────────────────────────────────────────────────────
# Após criar a instância: pegue host/user na UI ou via CLI.
LAKEBASE_INSTANCE_NAME=databricks-certifica-db
PGHOST=
PGPORT=5432
PGDATABASE=databricks_postgres
PGUSER=
# Deixe PGPASSWORD vazio para gerar credencial OAuth automaticamente.
PGPASSWORD=
PGSSLMODE=require
PGSCHEMA=databricks_certifica

# ── Geração via LLM (Foundation Model API) ──────────────────────────────────────
LLM_ENDPOINT=databricks-claude-opus-4-8

# ── App ──────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3006
